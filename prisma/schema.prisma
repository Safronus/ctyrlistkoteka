// Prisma schema pro Čtyřlístkotéka
// Detail viz docs/data-schema.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================================
//  ENUMS
// ============================================================

enum FindState {
  NORMAL
  ANONYMIZED
  DONATED
  LOST
  NO_GPS
  NO_PHOTO
  LOCATION_MISSING // nález není přiřazen k žádné lokalitě (BEZLOKACE)
  LOCATION_GONE // lokalita existovala, ale fyzicky zanikla (LOKACE-NEEXISTUJE) — kód lokality má prefix "NEEXISTUJE-"
  NOT_PICKED
  GIGANT // čtyřlístek mimořádně velkých rozměrů — kosmetický stav nesený přes LokaceStavyPoznamky.json (stavy.GIGANT)
}

enum ImageType {
  ORIGINAL
  CROP
}

// ============================================================
//  LOCATIONS
// ============================================================

model Location {
  id                 Int     @id // MAP_ID z názvu souboru lokační mapy (shoduje se s klíči v LokaceStavyPoznamky.json "lokace")
  code               String  @unique @db.VarChar(150) // "RATIBOŘ_POLE001f", "HLUBOKÁ NAD VLTAVOU_GOLFCLUB001", "NEEXISTUJE-ZLÍN_JSVAHY-JAVOROVÁ002"
  codeTransliterated String  @map("code_transliterated") @db.VarChar(150) // ASCII-safe forma z toAsciiCode() — convenience, ne přirozený klíč
  cadastralArea      String  @map("cadastral_area") @db.VarChar(100) // "RATIBOŘ"; fallback = celý code
  locationType       String? @map("location_type") @db.VarChar(100) // "POLE", "JSVAHY-UTB-U5-Z" — může chybět pro HOŠŤÁLKOVÁ001
  number             Int?    @db.SmallInt // 000–999, může být null pro RATIBOŘ_DOMA-JALOVEC
  subpart            String? @db.Char(1) // "a", "f", …
  displayName        String  @map("display_name") @db.VarChar(500) // z popisu mapy (může být dlouhý)
  description        String? @db.Text

  // PostGIS geometry (raw SQL pro čtení/zápis)
  centerPoint Unsupported("geometry(Point, 4326)")?   @map("center_point")
  polygon     Unsupported("geometry(Polygon, 4326)")?

  // Optional 2-level hierarchy. Subparts of a master location (e.g. the
  // 7 fragments of RATIBOŘ_POLE001 shown as 001a..001g) declare their
  // parent through data/meta/LokaceHierarchie.json — the subpart letter
  // ALONE isn't a reliable hierarchy signal because some 001a/001b pairs
  // are peers, not children. Max depth 2 is enforced by the sync script.
  parentId Int?       @map("parent_id")
  parent   Location?  @relation("LocationParent", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children Location[] @relation("LocationParent")

  // For child locations only: when true their polygon overlays the
  // parent on /mapa by default (no sidebar opt-in needed). Driven by
  // the `{ "code": ..., "map": true }` form in LokaceHierarchie.json;
  // sync sets it. Always false for top-level locations (they're shown
  // regardless). See docs/admin-overview.md.
  showOnMapByDefault Boolean @default(false) @map("show_on_map_by_default")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  maps  LocationMap[]
  finds Find[]

  @@index([cadastralArea])
  @@index([locationType])
  @@index([parentId])
  @@map("locations")
}

// ============================================================
//  LOCATION MAPS (PNG/JPEG lokační mapy)
// ============================================================

model LocationMap {
  id         Int      @id // MAP_ID z názvu souboru (1–99999)
  locationId Int      @map("location_id")
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  locationCode String  @map("location_code") @db.VarChar(150) // pro rychlé propojení
  description  String? @db.VarChar(500) // lidsky čitelný popis z názvu
  centerLat    Float   @map("center_lat") // GPS střed z názvu
  centerLng    Float   @map("center_lng")
  zoom         Int     @db.SmallInt // OSM zoom level

  imagePath   String @map("image_path") @db.VarChar(500) // cesta k souboru na disku
  imageBounds Json?  @map("image_bounds") // [[swLat, swLng], [neLat, neLng]]
  imageWidth  Int?   @map("image_width") // rozměry obrázku v px
  imageHeight Int?   @map("image_height")

  hasPolygon       Boolean @default(false) @map("has_polygon") // AOI_POLYGON v metadatech
  isAnonymized     Boolean @default(false) @map("is_anonymized") // z metadat souboru
  originalFilename String  @map("original_filename") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  finds Find[]

  @@index([locationId])
  @@index([locationCode])
  @@map("location_maps")
}

// ============================================================
//  FINDS
// ============================================================

model Find {
  id         Int          @id // ID z názvu souboru, NE autoincrement
  locationId Int?         @map("location_id")
  location   Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  mapId      Int?         @map("map_id")
  map        LocationMap? @relation(fields: [mapId], references: [id], onDelete: SetNull)

  foundAt      DateTime? @map("found_at") @db.Timestamptz(6) // z EXIF DateTimeOriginal, plný timestamp včetně H:M:S
  leafCount    Int       @default(4) @map("leaf_count") @db.SmallInt
  notes        String?   @db.Text // z JSON poznamky
  isAnonymized Boolean   @default(false) @map("is_anonymized") // z JSON anonymizace + filename

  // Denormalized vote count — cache pro O(1) výpis/žebříček. Sync přes
  // trigger v migraci (insert/delete na find_votes ↦ +1/-1 zde). Bez
  // tohoto sloupce by Top 10 muselo na každý request groupovat všech
  // ~17 k findů.
  voteCount Int @default(0) @map("vote_count")

  /// Optional per-find unlock code for anonymized donation photos.
  /// NULL means the find inherits the global FIND_PHOTO_UNLOCK_CODE
  /// env var; a non-null value overrides that secret for THIS find
  /// only — recipients of one gift get a personal code while the
  /// rest of the collection stays on the shared default. Set / cleared
  /// from /admin/files/donation-photos/<filename>.
  unlockCode String? @map("unlock_code") @db.VarChar(256)

  coordinates Unsupported("geometry(Point, 4326)")?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  images FindImage[]
  states FindStateAssignment[]
  votes  FindVote[]

  @@index([locationId])
  @@index([mapId])
  @@index([foundAt(sort: Desc)])
  @@index([leafCount])
  @@index([isAnonymized])
  @@index([voteCount(sort: Desc)])
  @@map("finds")
}

// ============================================================
//  FIND VOTES (veřejné hlasování „palec nahoru")
// ============================================================
//
// Každý hlas má dvě nezávislé identity:
//   - voterUuid     — UUID v httpOnly cookie (1 rok)
//   - fingerprint   — sha1(ip + ua + accept-lang + serverový salt)
// Dvě unique constraints zajistí, že OBĚ se musí lišit, aby šel nový
// hlas pro stejný nález. To zvládne casual cheating; útočník musí
// vymazat cookies *a* změnit IP/UA, aby tutéž věc lajknul podruhé.
//
// Pro RŮZNÉ nálezy stejná osoba hlasuje libovolně — to není potřeba
// chránit (dle zadání).
//
// `ipHash` a `userAgent` jsou jen pro audit + admin reverze (smazat
// hlasy z konkrétní IP/UUID). Plný IP nikdy neukládáme; sha1 +
// serverový salt → nelze přímo dohledat osobu z DB dumpu.

model FindVote {
  findId      Int       @map("find_id")
  find        Find      @relation(fields: [findId], references: [id], onDelete: Cascade)
  voterUuid   String    @map("voter_uuid") @db.Uuid                          // z cookie
  fingerprint String    @map("fingerprint") @db.Char(40)                      // sha1
  votedAt     DateTime  @default(now()) @map("voted_at") @db.Timestamptz
  ipHash      String    @map("ip_hash") @db.Char(40)                          // audit-only, sha1
  userAgent   String?   @map("user_agent") @db.VarChar(500)                   // audit-only

  @@id([findId, voterUuid])
  @@unique([findId, fingerprint], name: "find_votes_fingerprint_unique")
  @@index([votedAt(sort: Desc)])
  @@index([fingerprint])
  @@index([voterUuid])
  @@map("find_votes")
}

// ============================================================
//  FIND IMAGES
// ============================================================

model FindImage {
  id     Int  @id @default(autoincrement())
  findId Int  @map("find_id")
  find   Find @relation(fields: [findId], references: [id], onDelete: Cascade)

  imageType        ImageType @default(ORIGINAL) @map("image_type") // ORIGINAL nebo CROP
  originalFilename String    @map("original_filename") @db.VarChar(500)
  originalSha1     String    @map("original_sha1") @db.Char(40) // pro detekci změn
  webPath          String    @map("web_path") @db.VarChar(500) // /generated/web/{sha}.webp
  thumbPath        String    @map("thumb_path") @db.VarChar(500) // /generated/thumb/{sha}.webp

  width     Int
  height    Int
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(0) @map("sort_order") @db.SmallInt

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([findId])
  @@index([isPrimary])
  @@map("find_images")
}

// ============================================================
//  FIND STATE ASSIGNMENTS (M:N)
// ============================================================

model FindStateAssignment {
  findId Int       @map("find_id")
  find   Find      @relation(fields: [findId], references: [id], onDelete: Cascade)
  state  FindState

  @@id([findId, state])
  @@index([state])
  @@map("find_state_assignments")
}
