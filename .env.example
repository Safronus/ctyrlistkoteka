# Zkopíruj tento soubor na .env a doplň skutečné hodnoty.
# .env je v .gitignore a NIKDY se necommituje.

# --- Databáze ---
# Lokální dev (Docker Compose):
DATABASE_URL=postgresql://ctyrlist:ctyrlist_dev@localhost:5432/ctyrlistkoteka
# Produkce (na VPS):
# DATABASE_URL=postgresql://ctyrlist:SILNE_HESLO@localhost:5432/ctyrlistkoteka

# --- Aplikace ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Produkce:
# NEXT_PUBLIC_SITE_URL=https://ctyrlistkoteka.cz

# --- Cesty k datům ---
# Lokální dev (ukázková data):
DATA_DIR=./data
GENERATED_DIR=./public/generated
# Produkce:
# DATA_DIR=/var/ctyrlistkoteka/data
# GENERATED_DIR=/var/ctyrlistkoteka/generated

# --- Redis (volitelné) ---
# Zapnout pro cache statistik. Pokud nenastaveno, používá se in-memory cache.
REDIS_URL=redis://localhost:6379

# --- Logování ---
LOG_LEVEL=info
# Produkce: info, debug jen při ladění

# --- Node ---
NODE_ENV=development
# Produkce: NODE_ENV=production

# --- GoatCounter analytika ---
# Self-hosted GoatCounter na separátní subdoméně. Pixel script v patičce
# loguje pageview, server-side fetcher pak čerpá total z /api/v0 do
# malého počítadla v patičce. Při prázdných hodnotách jsou jednotlivé
# části vypnuté (pixel pokud chybí NEXT_PUBLIC_GOATCOUNTER_SITE,
# počítadlo pokud chybí GOATCOUNTER_API_KEY).
GOATCOUNTER_API_URL=https://stats.ctyrlistkoteka.cz
GOATCOUNTER_API_KEY=
NEXT_PUBLIC_GOATCOUNTER_SITE=https://stats.ctyrlistkoteka.cz
