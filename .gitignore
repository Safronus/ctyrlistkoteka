# Node / pnpm
node_modules/
.pnpm-store/

# Next.js
.next/
out/
dist/

# Environment
.env
.env.local
.env.*.local

# Logs
logs/
*.log
*.jsonl
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Data (nepatří do gitu, jsou na VPS / lokálně)
# Pattern is rooted (/data/) so it only matches the project-root data
# tree of user assets — nested paths like src/data/ for bundled
# build-time JSON stay tracked.
/data/
# Exception: clover-texts JSON files live in data/meta/ but are
# project assets (not user data), so they belong in git. Admin UI
# writes to these files at runtime; git history is the source of
# truth for the canonical bundled defaults.
!/data/meta/
!/data/meta/clover-texts*.json
public/generated/
/var/

# Testy
coverage/
playwright-report/
test-results/
.vitest/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Claude Code — per-machine local permissions / settings (obsahují
# absolutní cesty k profilu uživatele, není to citlivé, ale ani sdílené).
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Self-hosted GitHub Actions runner — pokud někdo runner omylem
# rozbalí uvnitř repa (patří mimo web root, do /home/app/actions-runner),
# ať se aspoň nedostane do gitu. Obsahuje creds (.credentials/.runner).
actions-runner/

# Prisma generated
prisma/generated/
src/generated/

# Next.js typy (auto-generated)
next-env.d.ts

# Dočasné
tmp/
*.tsbuildinfo

# Mockup output (regenerable from scripts/mockups/*.mjs)
scripts/mockups/*.svg
